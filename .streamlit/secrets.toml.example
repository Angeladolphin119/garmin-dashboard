# ============================================================
# Streamlit Cloud 部署用的 secrets 設定
# 把這個檔案的內容貼到 Streamlit Cloud 的 Secrets 欄位
# （本機執行不需要這個檔案，用 .env + credentials.json 就好）
# ============================================================

# Google Sheet ID
SHEET_ID = "你的_Google_Sheet_ID"

# Google 服務帳戶金鑰（把 credentials.json 的內容整個貼進來）
[gcp_service_account]
type = "service_account"
project_id = "你的專案ID"
private_key_id = "金鑰ID"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "服務帳號email@專案.iam.gserviceaccount.com"
client_id = "數字ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
